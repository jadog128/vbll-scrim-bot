# ── Scrim Bot — .env.scrim ──────────────────────────────────────────────────
# Fill in all values before running the bot.
# Save this file as: .env.scrim  (in the same folder as scrim.js)

# Your NEW scrim bot token (create a separate bot on discord.com/developers)
SCRIM_DISCORD_TOKEN=paste_your_scrim_bot_token_here

# Application ID of the scrim bot
SCRIM_CLIENT_ID=paste_your_scrim_client_id_here

# Your Discord server (guild) ID  — same server you're already using
SCRIM_GUILD_ID=1353515180507664416

# Turso database — you can reuse the same Turso DB (it uses different table names)
# Or create a new Turso database at turso.tech
SCRIM_TURSO_URL=libsql://your-scrim-db.turso.io
SCRIM_TURSO_TOKEN=your_turso_token_here
